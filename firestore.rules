rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this app, only the owner/guptaztech is admin
      return isSignedIn() && (
        request.auth.token.email == 'guptaztech@gmail.com'
      );
    }

    function isApprovedWriter() {
      return isSignedIn() && (
        isAdmin() || (
          exists(/databases/$(database)/documents/applications/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/applications/$(request.auth.uid)).data.status == 'approved'
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Blogs: Public read, Admin/Writers write
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if (isAdmin() || isApprovedWriter()) && isValidId(blogId);
      allow update: if (isAdmin() || 
                       (isApprovedWriter() && resource.data.authorId == request.auth.uid) || 
                       (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])));
      allow delete: if isAdmin() || (isApprovedWriter() && resource.data.authorId == request.auth.uid);

      // Comments: Anyone can create, any one can read
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isValidId(commentId) && request.resource.data.text.size() < 1000;
        allow update, delete: if isAdmin();
      }
    }

    // Subscribers: Anyone can create, Admin can read
    match /subscribers/{subId} {
      allow create: if isValidId(subId) && request.resource.data.email.size() < 256;
      allow read, update, delete: if isAdmin();
    }

    // Applications: Anyone can create/update (pending) as owner, Admin can read/update/delete all
    match /applications/{appId} {
      allow create, update: if isSignedIn() && (
        isAdmin() || (
          appId == request.auth.uid &&
          request.resource.data.status == 'pending' &&
          request.resource.data.name is string &&
          request.resource.data.comments is string &&
          request.resource.data.name.size() < 200
        )
      );
      allow read: if isAdmin() || (isSignedIn() && appId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Config: Publicly readable for logo/branding, Admin can write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profiles: Users can edit their own profiles, everyone can read
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
    }
  }
}
